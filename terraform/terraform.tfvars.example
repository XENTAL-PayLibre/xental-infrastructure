# Copy to terraform.tfvars and adjust. Do NOT commit terraform.tfvars.
aws_region = "eu-west-1"

# Contents of your PUBLIC key (e.g. ~/.ssh/xental_deploy.pub). The matching
# private key becomes the GitHub secret SSH_PRIVATE_KEY.
ssh_public_key = "ssh-ed25519 AAAA... you@example.com"

# Optional: narrow SSH exposure (default is open, key-only auth).
# ssh_ingress_cidr = "203.0.113.10/32"

instance_types = {
  staging    = "t3.small"
  production = "t3.medium"
}
