# ============================================================================
# STAGING (non-secret) configuration.
# Layer order at render time:  common.env.example -> staging.env.example
#                              -> versions/staging.env -> GitHub secrets
# This file is committed; the deploy renders the real runtime file from these
# layers plus the secrets injected by the GitHub Actions job.
# ============================================================================

ENVIRONMENT=staging

# --- Domains -----------------------------------------------------------------
# A records for these point at the staging Elastic IP (52.30.180.28).
DOMAIN=xental.online
XENTAL_API_HOST=api.staging.xental.online
PAYLIBRE_API_HOST=paylibre.staging.xental.online

# --- TLS ---------------------------------------------------------------------
ACME_EMAIL=jeffreyliaison@gmail.com

# --- App runtime -------------------------------------------------------------
XENTAL_ASPNETCORE_ENVIRONMENT=Staging
PAYLIBRE_ASPNETCORE_ENVIRONMENT=Staging

# ============================================================================
# SECRETS (NOT stored here) — set as GitHub Environment secrets on the
# "staging" environment of the xental-infrastructure repo. The deploy job
# injects them into render-env.sh:
#
#   POSTGRES_PASSWORD
#   XENTAL_DB_PASSWORD
#   PAYLIBRE_DB_PASSWORD
#   REDIS_PASSWORD
#   GHCR_USER            (bot/user that can read GHCR packages)
#   GHCR_TOKEN           (read:packages token)
#   TRAEFIK_DASHBOARD_AUTH   (htpasswd "user:hash"; staging only)
#
#   --- Xental backend (Stage 0–3) ---
#   JWT_SIGNING_KEY      (REQUIRED; >= 32 bytes, unique per env)
#   RESEND_API_KEY       (transactional email; magic links + password reset)
#   GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET     (optional: Google login)
#   GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET     (optional: GitHub login)
#   NOMBA_CLIENT_ID / NOMBA_CLIENT_SECRET       (Phase 2 payments)
#   NOMBA_ACCOUNT_ID / NOMBA_SUB_ACCOUNT_ID     (Phase 2 payments)
#
# Also set as Environment-level VARIABLES (not secrets): SSH_HOST, SSH_USER.
# And the Environment secret SSH_PRIVATE_KEY for the deploy SSH connection.
#
# OAuth callback URLs to register with the providers:
#   https://api.staging.xental.online/api/v1/auth/oauth/google/callback
#   https://api.staging.xental.online/api/v1/auth/oauth/github/callback
# ============================================================================
