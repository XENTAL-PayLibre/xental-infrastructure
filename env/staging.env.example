# ============================================================================
# STAGING (non-secret) configuration.
# Layer order at render time:  common.env.example -> staging.env.example
#                              -> versions/staging.env -> SSM secrets
# Copy is informational; the deploy renders the real file from these + SSM.
# ============================================================================

ENVIRONMENT=staging

# --- Domains (PLACEHOLDER until the domain is purchased) ---------------------
# Update DOMAIN and the two host values once DNS is available.
DOMAIN=example.com
XENTAL_API_HOST=xental-api.staging.example.com
PAYLIBRE_API_HOST=paylibre-api.staging.example.com

# --- TLS ---------------------------------------------------------------------
ACME_EMAIL=devops@example.com

# --- App runtime -------------------------------------------------------------
XENTAL_ASPNETCORE_ENVIRONMENT=Staging
PAYLIBRE_ASPNETCORE_ENVIRONMENT=Staging

# ============================================================================
# SECRETS (NOT stored here) — provisioned in AWS SSM Parameter Store as
# SecureString under /xental/staging/<NAME> and merged at deploy time:
#
#   /xental/staging/POSTGRES_PASSWORD
#   /xental/staging/XENTAL_DB_PASSWORD
#   /xental/staging/PAYLIBRE_DB_PASSWORD
#   /xental/staging/REDIS_PASSWORD
#   /xental/staging/TRAEFIK_DASHBOARD_AUTH      (htpasswd "user:hash")
# ============================================================================
