# ============================================================================
# COMMON (non-secret) defaults shared by every environment.
# Copied as the first layer when rendering a runtime env file.
# Real secrets never live here — they come from AWS SSM Parameter Store.
# ============================================================================

# Pinned infrastructure image versions (overridable per env).
TRAEFIK_IMAGE=traefik:v3.3
POSTGRES_IMAGE=postgres:17-alpine
REDIS_IMAGE=redis:7-alpine

# Database/user names (not secret; passwords come from SSM).
POSTGRES_USER=xental_admin
XENTAL_DB_NAME=xental
XENTAL_DB_USER=xental_app
PAYLIBRE_DB_NAME=paylibre
PAYLIBRE_DB_USER=paylibre_app
