# ============================================================================
# PRODUCTION (non-secret) configuration.
# Layer order at render time:  common.env.example -> prod.env.example
#                              -> versions/prod.env -> SSM secrets
# ============================================================================

ENVIRONMENT=production

# --- Domains (PLACEHOLDER until the domain is purchased) ---------------------
DOMAIN=example.com
XENTAL_API_HOST=api.xental.example.com
PAYLIBRE_API_HOST=api.paylibre.example.com

# --- TLS ---------------------------------------------------------------------
ACME_EMAIL=devops@example.com

# --- App runtime -------------------------------------------------------------
XENTAL_ASPNETCORE_ENVIRONMENT=Production
PAYLIBRE_ASPNETCORE_ENVIRONMENT=Production

# ============================================================================
# SECRETS (NOT stored here) — AWS SSM Parameter Store, SecureString under
# /xental/production/<NAME>, merged at deploy time:
#
#   /xental/production/POSTGRES_PASSWORD
#   /xental/production/XENTAL_DB_PASSWORD
#   /xental/production/PAYLIBRE_DB_PASSWORD
#   /xental/production/REDIS_PASSWORD
#
# Note: the Traefik dashboard is disabled in production, so no dashboard auth.
# ============================================================================
