# ============================================================================
# PRODUCTION (non-secret) configuration.
# Layer order at render time:  common.env.example -> production.env.example
#                              -> versions/production.env -> GitHub secrets
# ============================================================================

ENVIRONMENT=production

# --- Domains -----------------------------------------------------------------
# A records for these point at the production Elastic IP (18.203.125.98).
DOMAIN=xental.online
XENTAL_API_HOST=api.xental.online
PAYLIBRE_API_HOST=paylibre.xental.online

# --- TLS ---------------------------------------------------------------------
ACME_EMAIL=ukemetim2222@gmail.com

# --- App runtime -------------------------------------------------------------
XENTAL_ASPNETCORE_ENVIRONMENT=Production
PAYLIBRE_ASPNETCORE_ENVIRONMENT=Production

# Frontend URL (user-facing pages) + CORS origins allowed to call the API with cookies.
FRONTEND_URL=https://xental.online
CORS_ALLOWED_ORIGINS=https://xental.online

# ============================================================================
# SECRETS (NOT stored here) — set as GitHub Environment secrets on the
# "production" environment of the xental-infrastructure repo:
#
#   POSTGRES_PASSWORD
#   XENTAL_DB_PASSWORD
#   PAYLIBRE_DB_PASSWORD
#   REDIS_PASSWORD
#   GHCR_USER
#   GHCR_TOKEN
#
#   --- Xental backend (Stage 0–3) ---
#   JWT_SIGNING_KEY      (REQUIRED; >= 32 bytes, DIFFERENT from staging)
#   RESEND_API_KEY       (transactional email; magic links + password reset)
#   GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET       (optional: Google login)
#   GH_OAUTH_CLIENT_ID / GH_OAUTH_CLIENT_SECRET   (optional: GitHub login;
#                          GITHUB_ prefix is reserved by Actions)
#   NOMBA_CLIENT_ID / NOMBA_CLIENT_SECRET       (Phase 2 payments — LIVE creds)
#   NOMBA_ACCOUNT_ID / NOMBA_SUB_ACCOUNT_ID     (Phase 2 payments — LIVE)
#
# Plus Environment VARIABLES SSH_HOST, SSH_USER and the Environment secret
# SSH_PRIVATE_KEY. The Traefik dashboard is disabled in production (no auth secret).
#
# OAuth callback URLs to register with the providers:
#   https://api.xental.online/api/v1/auth/oauth/google/callback
#   https://api.xental.online/api/v1/auth/oauth/github/callback
# ============================================================================
