# ============================================================================
# PRODUCTION (non-secret) configuration.
# Layer order at render time:  common.env.example -> production.env.example
#                              -> versions/production.env -> GitHub secrets
# ============================================================================

ENVIRONMENT=production

# --- Domains (PLACEHOLDER until the domain is purchased) ---------------------
DOMAIN=example.com
XENTAL_API_HOST=api.xental.example.com
PAYLIBRE_API_HOST=api.paylibre.example.com

# --- TLS ---------------------------------------------------------------------
ACME_EMAIL=devops@example.com

# --- App runtime -------------------------------------------------------------
XENTAL_ASPNETCORE_ENVIRONMENT=Production
PAYLIBRE_ASPNETCORE_ENVIRONMENT=Production

# ============================================================================
# SECRETS (NOT stored here) — set as GitHub Environment secrets on the
# "production" environment of the xental-infrastructure repo:
#
#   POSTGRES_PASSWORD
#   XENTAL_DB_PASSWORD
#   PAYLIBRE_DB_PASSWORD
#   REDIS_PASSWORD
#   GHCR_USER
#   GHCR_TOKEN
#
# Plus Environment VARIABLES SSH_HOST, SSH_USER and the Environment secret
# SSH_PRIVATE_KEY. The Traefik dashboard is disabled in production (no auth secret).
# ============================================================================
